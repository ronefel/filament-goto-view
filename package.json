{
  "name": "filament-goto-view",
  "displayName": "Filament Goto View",
  "description": "Navigate to Blade view files from $view strings in Filament PHP with Ctrl+Click. Includes real-time validation for missing views and intelligent autocomplete for view names.",
  "version": "1.1.1",
  "publisher": "Ronefel",
  "author": {
    "name": "Ronefel"
  },
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/ronefel/filament-goto-view"
  },
  "bugs": {
    "url": "https://github.com/ronefel/filament-goto-view/issues"
  },
  "homepage": "https://github.com/ronefel/filament-goto-view#readme",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "laravel",
    "filament",
    "filamentphp",
    "php",
    "blade",
    "goto",
    "navigation",
    "view"
  ],
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "activationEvents": [
    "onLanguage:php"
  ],
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "title": "Filament Goto View",
      "properties": {
        "filament-goto-view.viewPath": {
          "type": "string",
          "default": "resources/views",
          "description": "Relative path to the Laravel views folder."
        },
        "filament-goto-view.extension": {
          "type": "string",
          "default": ".blade.php",
          "description": "The file extension of your view files."
        },
        "filament-goto-view.projectSubFolder": {
          "type": "string",
          "default": "",
          "description": "Specify a subfolder if your Laravel project is not in the workspace root (e.g., 'src' or 'api')."
        }
      }
    }
  },
  "scripts": {
    "lint": "eslint .",
    "test": "npm run lint && vscode-test",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.107.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "eslint": "^9.39.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}